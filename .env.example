# 通宝奖励查询系统 - 环境配置
# 复制此文件为 .env 并填入你的配置

# ========== 腾讯文档 API 配置 ==========
# 申请地址: https://docs.qq.com/open/
# 步骤:
#   1. 打开 https://docs.qq.com/open/
#   2. 点击「创建应用」
#   3. 填写应用名称（如：通宝查询系统）
#   4. 获取 AppID、AppKey、AppSecret

TENCENT_DOC_APP_ID=你的APP_ID
TENCENT_DOC_APP_KEY=你的APP_KEY
TENCENT_DOC_APP_SECRET=你的APP_SECRET

# ========== 文档配置 ==========
# 打开你的在线表格，URL类似: https://docs.qq.com/sheet/DXXXXXXXXXXXX
# 其中 DXXXXXXXXXXXX 就是文档ID
DOC_ID=你的文档ID

# 工作表名称（默认Sheet1，如果你的表格叫其他名字就改这里）
SHEET_ID=Sheet1

# ========== 同步配置 ==========
# 自动同步间隔（秒），默认3600=1小时
SYNC_INTERVAL=3600

# ========== 服务配置 ==========
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false
